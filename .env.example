# DOTSY API Keys Configuration
# Copy this file to .env and fill in your API keys

# Mistral AI (Default)
MISTRAL_API_KEY=your-mistral-api-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key-here

# OpenRouter (Access to Qwen, Llama, and many more models)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Groq (Fast inference)
GROQ_API_KEY=your-groq-api-key-here

# Bytez
BYTEZ_API_KEY=your-bytez-api-key-here

# Mulerouter
MULEROUTER_API_KEY=your-mulerouter-api-key-here

# Together AI (Alternative provider for Qwen and other open models)
TOGETHER_API_KEY=your-together-api-key-here

# Local models (no API key needed)
# LlamaCPP - Set path to your model
# OLLAMA - Runs locally, no key needed
